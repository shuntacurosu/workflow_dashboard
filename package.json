{
  "name": "workflow-dashboard-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend for workflow dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:backend": "nodemon server.js",
    "dev:frontend": "npm run dev --prefix dashboard",
    "dev": "concurrently --names \"BE,FE\" --prefix-colors \"blue,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "js-yaml": "^4.1.1",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1"
  }
}
